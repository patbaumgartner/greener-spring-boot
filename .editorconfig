root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,kt,kts}]
indent_style = tab

[*.{xml,yml,yaml,json,json5}]
indent_style = space
indent_size = 2

[*.{md,txt}]
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
