{
  // Renovate configuration for greener-spring-boot
  //
  // Dependabot already covers: Maven, Gradle dependencies.
  // Renovate handles: Gradle wrapper, tool versions in workflows, GitHub Actions (SHA-pinned).
  //
  // Documentation: https://docs.renovatebot.com/configuration-options/
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
  ],

  // ── Only enable managers NOT covered by Dependabot ──────────────────────────
  enabledManagers: ["gradle-wrapper", "custom.regex", "github-actions"],

  // ── Schedule ────────────────────────────────────────────────────────────────
  schedule: ["before 7am on monday"],
  timezone: "Europe/Zurich",

  // ── PR limits ───────────────────────────────────────────────────────────────
  prConcurrentLimit: 10,
  prHourlyLimit: 4,

  // ── Labels ──────────────────────────────────────────────────────────────────
  labels: ["dependencies"],

  // ── Gradle wrapper ──────────────────────────────────────────────────────────
  "gradle-wrapper": {
    enabled: true,
  },

  // ── Custom regex managers for tool versions in GitHub Actions workflows ─────
  // Tracks version env-vars that Dependabot cannot discover.
  customManagers: [
    {
      customType: "regex",
      fileMatch: ["\\.github/workflows/.+\\.yml$"],
      matchStrings: [
        "OHA_VERSION:\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "hatoo/oha",
      datasourceTemplate: "github-releases",
      extractVersionTemplate: "^v(?<version>.+)$",
    },
    {
      customType: "regex",
      fileMatch: ["\\.github/workflows/.+\\.yml$"],
      matchStrings: [
        "BOMBARDIER_VERSION:\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "codesenberg/bombardier",
      datasourceTemplate: "github-releases",
      extractVersionTemplate: "^v(?<version>.+)$",
    },
    {
      customType: "regex",
      fileMatch: ["\\.github/workflows/.+\\.yml$"],
      matchStrings: [
        "GATLING_VERSION:\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "gatling/gatling",
      datasourceTemplate: "github-releases",
      extractVersionTemplate: "^v(?<version>.+)$",
    },
    {
      customType: "regex",
      fileMatch: ["\\.github/workflows/.+\\.yml$"],
      matchStrings: [
        "JOULAR_CORE_VERSION:\\s*\"(?<currentValue>[^\"]+)\"",
      ],
      depNameTemplate: "joular/joularcore",
      datasourceTemplate: "github-releases",
    },
  ],

  // ── Package rules ──────────────────────────────────────────────────────────
  packageRules: [
    // Group all workflow tool version updates into a single PR
    {
      matchManagers: ["custom.regex"],
      groupName: "Workflow tool versions",
      labels: ["dependencies", "tools"],
    },

    {
      matchManagers: ["gradle-wrapper"],
      labels: ["dependencies", "gradle"],
    },

    // Automerge minor/patch for tools and Gradle wrapper
    {
      matchManagers: ["custom.regex", "gradle-wrapper"],
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
      automergeType: "pr",
    },

    // GitHub Actions: group all action digest updates into a single PR
    {
      matchManagers: ["github-actions"],
      groupName: "GitHub Actions",
      labels: ["dependencies", "github-actions"],
    },

    // GitHub Actions: automerge digest (SHA) and minor/patch updates
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["digest", "minor", "patch"],
      automerge: true,
      automergeType: "pr",
    },

    // Major version bumps always require manual review
    {
      matchUpdateTypes: ["major"],
      automerge: false,
      labels: ["dependencies", "major-update"],
    },
  ],

  // ── Vulnerability alerts ────────────────────────────────────────────────────
  vulnerabilityAlerts: {
    enabled: true,
    labels: ["security", "dependencies"],
    schedule: ["at any time"],
  },
}
