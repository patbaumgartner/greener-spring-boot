# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Shell scripts must have LF even on Windows
*.sh text eol=lf

# Windows batch files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never diff or merge
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary

# Linguist overrides — keep GitHub language stats focused on Java
examples/workloads/gatling/src/**/*.scala linguist-language=Scala
examples/workloads/k6/*.js linguist-detectable=false
examples/workloads/locust/*.py linguist-detectable=false
examples/**/*.sh linguist-detectable=false
renovate.json5 linguist-detectable=false
